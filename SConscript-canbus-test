Import('env')

localEnv = env.Clone()

localEnv.Append(
  CPPPATH=[
    '#canbus',
    '#canbus/common',
    '#canbus/socketcan',
    '#canbus/libcanard/libcanard'
  ]
)

localEnv.CompilationDatabase()
localEnv.Program(
  target = '../bin/canbus-test', # relative to build/canbus-test
  source = 
    Glob('canbus/*.cpp') +
    Glob('canbus/common/*.cpp') +
    Glob('canbus/socketcan/*.c') +
    Glob('canbus/libcanard/libcanard/*.c'),

  
  LIBS = ['socketcan', 'boost_thread']
)


